# ── Framework ─────────────────────────────

# --- Utils ---
GEN_LOG_UTILS=true
GEN_WAIT_UTILS=true
GEN_SCREENSHOT_UTILS=true
GEN_EXTENT_MANAGER=true
GEN_EXCEL_UTILS=false

# --- Listeners ---
GEN_TEST_LISTENER=true

# --- Suites ---
GEN_SMOKE_SUITE=true
GEN_REGRESSION_SUITE=true
GEN_CROSS_BROWSER_SUITE=false

# --- Resources ---
GEN_LOG4J2_XML=true

# --- Test Data ---
GEN_USERS_CSV=true
GEN_TESTDATA_EXCEL=false
GEN_TESTDATA_JSON=true
GEN_LOCATORS_JSON=true

# --- Properties ---
GEN_CONFIG_PROPERTIES=true
GEN_MESSAGES_PROPERTIES=true


# ── POM ───────────────────────────────────

# --- Dependencies ---
ENABLE_EXTENT=true
ENABLE_ALLURE=false
ENABLE_POI=false
ENABLE_JACKSON=true
ENABLE_GSON=false
ENABLE_RESTASSURED=false

# --- Plugins ---
ENABLE_FAILSAFE_PLUGIN=true
ENABLE_ALLURE_PLUGIN=false

# --- Java ---
JAVA_VERSION=17